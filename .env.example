# Web app access
APP_PASSCODE=change-this-before-deploy
SESSION_SECRET=generate-a-long-random-secret

# The UI and backend are hard-wired to this one display name.
TARGET_GROUP_NAME=SSR attendence Group

# No phone number is required here. The WhatsApp account is selected by scanning
# the QR code with the phone/account you want this app to use.
# For best isolation, use a dedicated WhatsApp account that belongs only to this group.

# Strongly recommended: set the actual WhatsApp group id after first setup.
# Example format usually looks like: 120363000000000000@g.us
WHATSAPP_GROUP_ID=

# Transport options:
# - webjs: send through WhatsApp Web using whatsapp-web.js
# - mock: local dry-run mode for UI checks; does not send to WhatsApp
WHATSAPP_TRANSPORT=webjs

# Render persistent disk path. For local development, leave this blank or use ./.wwebjs_auth
WWEBJS_AUTH_DIR=

# Free-tier optimization:
# - false keeps Chrome closed until someone opens the app after login
# - after the browser is idle, it shuts down and restarts on the next status/send request
WHATSAPP_AUTO_START=false
WHATSAPP_IDLE_SHUTDOWN_MS=600000

# Optional local Chrome/Chromium path if Puppeteer did not download its own browser.
# Windows example: C:\Program Files\Google\Chrome\Application\chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# Server
PORT=10000
NODE_ENV=production
